{
  "name": "webcomponent-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter remote-webcomponent --filter host-react dev",
    "dev:remote": "pnpm --filter remote-webcomponent dev",
    "dev:host": "pnpm --filter host-react dev",
    "build": "pnpm --filter fb-ui-library build && pnpm --filter remote-webcomponent build && pnpm --filter host-react build",
    "build:remote": "pnpm --filter remote-webcomponent build",
    "build:host": "pnpm --filter host-react build",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
